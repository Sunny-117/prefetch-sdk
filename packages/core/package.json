{
  "name": "@prefetch-sdk/core",
  "version": "0.0.1",
  "description": "Core utilities for prefetch SDK - pool, cache, and helpers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "prefetch",
    "preload",
    "cache",
    "request"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sunny-117/prefetch-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Sunny-117/prefetch-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sunny-117/prefetch-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
