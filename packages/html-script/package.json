{
  "name": "@prefetch-sdk/html-script",
  "version": "0.1.0",
  "description": "HTML inline script for early prefetch before JS loads",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/runtime.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/runtime.ts --format esm,cjs --dts --watch",
    "lint": "oxlint src",
    "format": "oxlint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prefetch-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "oxlint": "^0.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": ["prefetch", "preload", "html", "script", "inline"],
  "license": "MIT"
}
