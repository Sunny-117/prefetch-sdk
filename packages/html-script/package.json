{
  "name": "@prefetch-sdk/html-script",
  "version": "0.0.1",
  "description": "HTML inline script for early prefetch before JS loads",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "keywords": ["prefetch", "preload", "html", "script"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sunny-117/prefetch-sdk.git",
    "directory": "packages/html-script"
  },
  "homepage": "https://github.com/Sunny-117/prefetch-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sunny-117/prefetch-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
