{
  "name": "@prefetch-sdk/react",
  "version": "0.1.0",
  "description": "React hooks and components for prefetch SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./swr": {
      "import": {
        "types": "./dist/swr.d.ts",
        "default": "./dist/swr.js"
      },
      "require": {
        "types": "./dist/swr.d.cts",
        "default": "./dist/swr.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint src",
    "format": "oxlint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prefetch-sdk/core": "workspace:*",
    "@prefetch-sdk/html-script": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "swr": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "swr": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "oxlint": "^0.15.0",
    "react": "^18.3.1",
    "swr": "^2.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": ["prefetch", "preload", "react", "hooks", "swr"],
  "license": "MIT"
}
