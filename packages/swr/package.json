{
  "name": "@prefetch-sdk/swr",
  "version": "1.0.0",
  "description": "SWR preload/prefetch integration",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "swr": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "swr": "^2.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "prefetch",
    "preload",
    "swr",
    "react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sunny-117/prefetch-sdk.git",
    "directory": "packages/swr"
  },
  "homepage": "https://github.com/Sunny-117/prefetch-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sunny-117/prefetch-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
